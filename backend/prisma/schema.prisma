generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  email         String?
  createdAt     DateTime @default(now())

  sites Site[]
}

model Site {
  id          String   @id @default(cuid())
  /// On-chain siteId — bytes32 hex (0x...)
  onchainId   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain      String   @unique
  /// USDC base units (6 decimals). Default 0.001 USDC = 1000 micros.
  priceMicros BigInt   @default(1000)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  events CrawlEvent[]
}

model CrawlEvent {
  id           String   @id @default(cuid())
  siteId       String
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  agentAddress String
  amountMicros BigInt
  publisherCut BigInt
  protocolCut  BigInt
  txHash       String   @unique
  nonce        String
  userAgent    String?
  path         String?
  createdAt    DateTime @default(now())

  @@index([siteId, createdAt])
}

model SiweNonce {
  value         String   @id
  walletAddress String
  used          Boolean  @default(false)
  expiresAt     DateTime

  @@index([walletAddress])
}
