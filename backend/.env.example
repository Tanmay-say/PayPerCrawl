# Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Supabase (PostgreSQL) ───────────────────────────────────────────────────
# DATABASE_URL = pooler (port 6543, ?pgbouncer=true&connection_limit=1) for the running API
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public
# DIRECT_URL = direct (5432) for `prisma migrate`. Optional locally.
DIRECT_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=public

# ─── Upstash (Redis TLS) ─────────────────────────────────────────────────────
# Upstash → your DB → "Redis URL" (must start with rediss://)
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=change-me-32-or-more-random-bytes-please
JWT_EXPIRES_IN=7d

# Base Sepolia (default public RPC; swap for Alchemy / Infura for prod)
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN_ID=84532

# Protocol fee — 1000 = 10% (publisher gets 90%, treasury 10%)
PROTOCOL_FEE_BPS=1000
